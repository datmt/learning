   "execution_count": null,
   "id": "l1000017",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 3. Cache demo — same query should be a cache hit\n",
    "print('Testing semantic cache...')\n",
    "r1 = httpx.post(f'{GATEWAY}/query', json={'query': QUERIES[0]}, timeout=60)\n",
    "r2 = httpx.post(f'{GATEWAY}/query', json={'query': 'Tell me about the Transformer architecture'}, timeout=60)\n",
