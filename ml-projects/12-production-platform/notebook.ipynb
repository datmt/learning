   "cell_type": "markdown",
   "id": "l1000004",
   "metadata": {},
   "source": [
    "## 2. RAG Service"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "l1000005",
   "metadata": {},
   "outputs": [],
   "source": [
    "rag_service_code = '''\n",
    "\"\"\"RAG Microservice — document ingestion and retrieval.\"\"\"\n",
    "import numpy as np\n",
    "from typing import List, Dict\n",
    "from fastapi import FastAPI\n",
    "from pydantic import BaseModel\n",
    "from sentence_transformers import SentenceTransformer\n",
    "import uvicorn\n",
    "\n",
    "app = FastAPI(title=\"RAG Service\", version=\"1.0\")\n",
    "\n",
    "# State\n",
    "embed_model = SentenceTransformer(\\'all-MiniLM-L6-v2\\')\n",
    "documents   : List[str] = []\n",
    "doc_embeddings: np.ndarray = None\n",
    "\n",
    "class IngestRequest(BaseModel):\n",
    "    texts: List[str]\n",
    "\n",
    "class QueryRequest(BaseModel):\n",
    "    query: str\n",
    "    k: int = 3\n",
    "\n",
    "@app.post(\"/ingest\")\n",
    "def ingest(req: IngestRequest):\n",
    "    global documents, doc_embeddings\n",
    "    documents.extend(req.texts)\n",
    "    embs = embed_model.encode(req.texts, convert_to_numpy=True)\n",
    "    if doc_embeddings is None:\n",
    "        doc_embeddings = embs\n",
    "    else:\n",
    "        doc_embeddings = np.vstack([doc_embeddings, embs])\n",
    "    # Normalise\n",
    "    norms = np.linalg.norm(doc_embeddings, axis=1, keepdims=True)\n",
    "    doc_embeddings = doc_embeddings / (norms + 1e-10)\n",
    "    return {\"status\": \"ok\", \"total_docs\": len(documents)}\n",
    "\n",
    "@app.post(\"/query\")\n",
    "def query(req: QueryRequest):\n",
    "    if doc_embeddings is None or len(documents) == 0:\n",
    "        return {\"chunks\": [], \"error\": \"No documents indexed\"}\n",
    "    q_emb = embed_model.encode([req.query], convert_to_numpy=True)[0]\n",
    "    q_emb = q_emb / (np.linalg.norm(q_emb) + 1e-10)\n",
    "    sims  = doc_embeddings @ q_emb\n",
    "    top_k = np.argsort(sims)[::-1][:req.k]\n",
    "    return {\n",
    "        \"chunks\": [{\n",
    "            \"text\": documents[i],\n",
    "            \"score\": float(sims[i])\n",
    "        } for i in top_k]\n",
    "    }\n",
    "\n",
    "@app.get(\"/health\")\n",
    "def health():\n",
    "    return {\"status\": \"ok\", \"docs\": len(documents)}\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    uvicorn.run(app, host=\"0.0.0.0\", port=8081, log_level=\"warning\")\n",
    "'''\n",
    "\n",
    "with open('rag_service.py', 'w') as f:\n",
    "    f.write(rag_service_code)\n",
    "print('rag_service.py written.')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "l1000006",
   "metadata": {},
   "source": [
    "## 3. LLM Service"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "l1000007",
   "metadata": {},
   "outputs": [],
   "source": [
    "llm_service_code = '''\n",
    "\"\"\"LLM Microservice — wraps Anthropic API with retry and cost logging.\"\"\"\n",
    "import time, json\n",
    "from fastapi import FastAPI, HTTPException\n",
    "from pydantic import BaseModel\n",
    "from typing import Optional\n",
    "import anthropic\n",
    "import uvicorn\n",
    "\n",
    "app    = FastAPI(title=\"LLM Service\", version=\"1.0\")\n",
    "client = anthropic.Anthropic()\n",
    "MODEL  = \"claude-haiku-4-5-20251001\"\n",
    "\n",
    "# Cost tracking (approximate Haiku pricing)\n",
    "COST_PER_INPUT_TOKEN  = 0.00000025   # $0.25 per 1M input tokens\n",
    "COST_PER_OUTPUT_TOKEN = 0.00000125   # $1.25 per 1M output tokens\n",
    "\n",
    "total_cost   = 0.0\n",
    "total_tokens = {\"input\": 0, \"output\": 0}\n",
    "\n",
    "class LLMRequest(BaseModel):\n",
    "    prompt: str\n",
    "    system: str = \"You are a helpful AI assistant.\"\n",
    "    max_tokens: int = 512\n",
    "    temperature: float = 0.7\n",
    "\n",
    "@app.post(\"/generate\")\n",
    "def generate(req: LLMRequest):\n",
    "    global total_cost, total_tokens\n",
    "\n",
    "    max_retries = 3\n",
    "    for attempt in range(max_retries):\n",
    "        try:\n",
    "            response = client.messages.create(\n",
    "                model=MODEL,\n",
    "                max_tokens=req.max_tokens,\n",
    "                system=req.system,\n",
    "                messages=[{\"role\": \"user\", \"content\": req.prompt}]\n",
    "            )\n",
    "            text   = response.content[0].text\n",
    "            usage  = response.usage\n",
    "\n",
    "            # Track costs\n",
    "            cost = usage.input_tokens * COST_PER_INPUT_TOKEN + usage.output_tokens * COST_PER_OUTPUT_TOKEN\n",
    "            total_cost += cost\n",
    "            total_tokens[\"input\"]  += usage.input_tokens\n",
    "            total_tokens[\"output\"] += usage.output_tokens\n",
    "\n",
    "            return {\n",
    "                \"text\":         text,\n",
    "                \"input_tokens\": usage.input_tokens,\n",
    "                \"output_tokens\": usage.output_tokens,\n",
    "                \"cost_usd\":     round(cost, 6)\n",
    "            }\n",
    "        except anthropic.RateLimitError:\n",
    "            if attempt < max_retries - 1:\n",
    "                time.sleep(2 ** attempt)  # exponential backoff\n",
    "            else:\n",
    "                raise HTTPException(status_code=429, detail=\"Rate limit exceeded\")\n",
    "        except Exception as e:\n",
    "            raise HTTPException(status_code=500, detail=str(e))\n",
    "\n",
    "@app.get(\"/cost\")\n",
    "def cost_report():\n",
    "    return {\n",
    "        \"total_cost_usd\":    round(total_cost, 6),\n",
    "        \"total_input_tokens\": total_tokens[\"input\"],\n",
    "        \"total_output_tokens\": total_tokens[\"output\"],\n",
    "        \"model\": MODEL\n",
    "    }\n",
    "\n",
    "@app.get(\"/health\")\n",
    "def health():\n",
    "    return {\"status\": \"ok\", \"model\": MODEL}\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    uvicorn.run(app, host=\"0.0.0.0\", port=8082, log_level=\"warning\")\n",
    "'''\n",
    "\n",
    "with open('llm_service.py', 'w') as f:\n",
    "    f.write(llm_service_code)\n",
    "print('llm_service.py written.')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "l1000008",
   "metadata": {},
   "source": [
    "## 4. Eval Service"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "l1000009",
   "metadata": {},
   "outputs": [],
   "source": [
    "eval_service_code = '''\n",
    "\"\"\"Evaluation Microservice — assess LLM response quality.\"\"\"\n",
    "from fastapi import FastAPI\n",
    "from pydantic import BaseModel\n",
    "from typing import List\n",
    "import uvicorn\n",
    "\n",
    "app = FastAPI(title=\"Eval Service\", version=\"1.0\")\n",
    "\n",
    "class EvalRequest(BaseModel):\n",
    "    query:    str\n",
    "    response: str\n",
    "    context:  List[str] = []   # retrieved chunks used as context\n",
    "\n",
    "def score_relevance(query: str, response: str) -> float:\n",
    "    \"\"\"Heuristic: fraction of query keywords found in response.\"\"\"\n",
    "    q_words = set(query.lower().split())\n",
    "    r_words = set(response.lower().split())\n",
    "    # Remove stopwords\n",
    "    stopwords = {\"the\", \"a\", \"an\", \"is\", \"are\", \"was\", \"were\", \"in\", \"on\", \"at\", \"to\", \"for\", \"of\", \"and\", \"or\"}\n",
    "    q_words -= stopwords\n",
    "    if not q_words:\n",
    "        return 0.5\n",
    "    overlap = len(q_words & r_words) / len(q_words)\n",
    "    return min(1.0, overlap * 1.5)   # scale up a bit\n",
    "\n",
    "def score_faithfulness(response: str, context: List[str]) -> float:\n",
    "    \"\"\"Heuristic: fraction of response words found in context.\"\"\"\n",
    "    if not context:\n",
    "        return 1.0   # no context = not grounded, but not unfaithful either\n",
    "    context_words = set(\" \".join(context).lower().split())\n",
    "    response_words = [w for w in response.lower().split() if len(w) > 4]\n",
    "    if not response_words:\n",
    "        return 0.5\n",
    "    overlap = sum(1 for w in response_words if w in context_words) / len(response_words)\n",
    "    return min(1.0, overlap * 2)\n",
    "\n",
    "def score_length(response: str) -> float:\n",
    "    \"\"\"Score based on response length — too short or too long is penalised.\"\"\"\n",
    "    n_words = len(response.split())\n",
    "    if n_words < 10:\n",
    "        return 0.3\n",
    "    elif n_words < 30:\n",
    "        return 0.6\n",
    "    elif n_words < 200:\n",
    "        return 1.0\n",
    "    else:\n",
    "        return 0.8\n",
    "\n",
    "@app.post(\"/evaluate\")\n",
    "def evaluate(req: EvalRequest):\n",
    "    rel    = score_relevance(req.query, req.response)\n",
    "    faith  = score_faithfulness(req.response, req.context)\n",
    "    length = score_length(req.response)\n",
    "    overall = (rel * 0.4 + faith * 0.4 + length * 0.2)\n",
    "\n",
    "    return {\n",
    "        \"relevance\":    round(rel, 3),\n",
    "        \"faithfulness\": round(faith, 3),\n",
    "        \"length_score\": round(length, 3),\n",
    "        \"overall\":      round(overall, 3),\n",
    "        \"grade\":        \"A\" if overall > 0.8 else \"B\" if overall > 0.6 else \"C\" if overall > 0.4 else \"D\"\n",
    "    }\n",
    "\n",
    "@app.get(\"/health\")\n",
    "def health():\n",
    "    return {\"status\": \"ok\"}\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    uvicorn.run(app, host=\"0.0.0.0\", port=8083, log_level=\"warning\")\n",
    "'''\n",
    "\n",
    "with open('eval_service.py', 'w') as f:\n",
    "    f.write(eval_service_code)\n",
    "print('eval_service.py written.')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "l1000010",
   "metadata": {},
   "source": [
    "## 5. API Gateway with Caching & Rate Limiting"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "l1000011",
   "metadata": {},
   "outputs": [],
   "source": [
    "gateway_code = '''\n",
    "\"\"\"API Gateway — rate limiting, semantic cache, cost tracking, routing.\"\"\"\n",
    "import time, json\n",
    "import numpy as np\n",
    "from typing import List, Dict\n",
    "from fastapi import FastAPI, HTTPException, Header\n",
    "from pydantic import BaseModel\n",
    "from sentence_transformers import SentenceTransformer\n",
    "import httpx\n",
    "import uvicorn\n",
    "\n",
    "app = FastAPI(title=\"API Gateway\", version=\"1.0\")\n",
    "\n",
    "# Service URLs\n",
    "RAG_URL  = \"http://localhost:8081\"\n",
    "LLM_URL  = \"http://localhost:8082\"\n",
    "EVAL_URL = \"http://localhost:8083\"\n",
    "\n",
    "# Semantic cache\n",
    "embed_model   = SentenceTransformer(\\'all-MiniLM-L6-v2\\')\n",
    "cache_queries : List[str]        = []\n",
    "cache_vectors : np.ndarray       = None\n",
    "cache_responses: List[dict]       = []\n",
    "CACHE_THRESHOLD = 0.92\n",
    "\n",
    "# Token bucket rate limiter\n",
    "BUCKET_CAPACITY = 10.0\n",
    "FILL_RATE       = 2.0   # tokens per second\n",
    "buckets: Dict[str, Dict] = {}\n",
    "\n",
    "# Metrics\n",
    "metrics = {\"requests\": 0, \"cache_hits\": 0, \"rate_limited\": 0, \"latencies\": []}\n",
    "\n",
    "def check_rate_limit(api_key: str) -> bool:\n",
    "    now = time.time()\n",
    "    if api_key not in buckets:\n",
    "        buckets[api_key] = {\"tokens\": BUCKET_CAPACITY, \"last_time\": now}\n",
    "    bucket = buckets[api_key]\n",
    "    # Refill\n",
    "    elapsed = now - bucket[\"last_time\"]\n",
    "    bucket[\"tokens\"] = min(BUCKET_CAPACITY, bucket[\"tokens\"] + elapsed * FILL_RATE)\n",
    "    bucket[\"last_time\"] = now\n",
    "    if bucket[\"tokens\"] >= 1.0:\n",
    "        bucket[\"tokens\"] -= 1.0\n",
    "        return True  # allowed\n",
    "    return False     # rate limited\n",
    "\n",
    "def check_cache(query: str):\n",
    "    global cache_vectors\n",
    "    if cache_vectors is None or len(cache_queries) == 0:\n",
    "        return None\n",
    "    q_emb = embed_model.encode([query], convert_to_numpy=True)[0]\n",
    "    q_emb = q_emb / (np.linalg.norm(q_emb) + 1e-10)\n",
    "    sims  = cache_vectors @ q_emb\n",
    "    best  = int(np.argmax(sims))\n",
    "    if sims[best] >= CACHE_THRESHOLD:\n",
    "        return cache_responses[best], sims[best]\n",
    "    return None\n",
    "\n",
    "def add_to_cache(query: str, response: dict):\n",
    "    global cache_vectors\n",
    "    cache_queries.append(query)\n",
    "    cache_responses.append(response)\n",
    "    emb = embed_model.encode([query], convert_to_numpy=True)[0]\n",
    "    emb = emb / (np.linalg.norm(emb) + 1e-10)\n",
    "    if cache_vectors is None:\n",
    "        cache_vectors = emb.reshape(1, -1)\n",
    "    else:\n",
    "        cache_vectors = np.vstack([cache_vectors, emb])\n",
    "\n",
    "class QueryRequest(BaseModel):\n",
    "    query: str\n",
    "    k: int = 3\n",
    "\n",
    "@app.post(\"/query\")\n",
    "async def handle_query(req: QueryRequest, x_api_key: str = Header(default=\"default\")):\n",
    "    t_start = time.time()\n",
    "    metrics[\"requests\"] += 1\n",
    "\n",
    "    # Rate limiting\n",
    "    if not check_rate_limit(x_api_key):\n",
    "        metrics[\"rate_limited\"] += 1\n",
    "        raise HTTPException(status_code=429, detail=\"Rate limit exceeded. Slow down.\")\n",
    "\n",
    "    # Semantic cache check\n",
    "    cached = check_cache(req.query)\n",
    "    if cached:\n",
    "        metrics[\"cache_hits\"] += 1\n",
    "        result = cached[0].copy()\n",
    "        result[\"cache_hit\"] = True\n",
    "        result[\"cache_similarity\"] = round(float(cached[1]), 3)\n",
    "        return result\n",
    "\n",
    "    async with httpx.AsyncClient(timeout=30) as client:\n",
    "        # 1. Retrieve context from RAG service\n",
    "        rag_resp = await client.post(f\"{RAG_URL}/query\", json={\"query\": req.query, \"k\": req.k})\n",
    "        rag_data = rag_resp.json()\n",
    "        chunks   = rag_data.get(\"chunks\", [])\n",
    "        context  = \"\\\\n\".join([c[\"text\"] for c in chunks])\n",
    "\n",
    "        # 2. Generate response from LLM service\n",
    "        prompt   = f\"Context:\\\\n{context}\\\\n\\\\nQuestion: {req.query}\\\\n\\\\nAnswer:\"\n",
    "        llm_resp = await client.post(f\"{LLM_URL}/generate\", json={\"prompt\": prompt, \"max_tokens\": 256})\n",
    "        llm_data = llm_resp.json()\n",
    "        answer   = llm_data.get(\"text\", \"\")\n",
    "\n",
    "        # 3. Evaluate response\n",
    "        eval_resp = await client.post(f\"{EVAL_URL}/evaluate\", json={\n",
    "            \"query\": req.query, \"response\": answer, \"context\": [c[\"text\"] for c in chunks]\n",
    "        })\n",
    "        eval_data = eval_resp.json()\n",
    "\n",
    "    latency = time.time() - t_start\n",
    "    metrics[\"latencies\"].append(latency)\n",
    "\n",
    "    result = {\n",
    "        \"query\":      req.query,\n",
    "        \"answer\":     answer,\n",
    "        \"chunks\":     chunks,\n",
    "        \"eval\":       eval_data,\n",
    "        \"cost_usd\":   llm_data.get(\"cost_usd\", 0),\n",
    "        \"latency_ms\": round(latency * 1000, 1),\n",
    "        \"cache_hit\":  False\n",
    "    }\n",
    "\n",
    "    add_to_cache(req.query, result)\n",
    "    return result\n",
    "\n",
    "@app.get(\"/metrics\")\n",
    "def get_metrics():\n",
    "    lats = metrics[\"latencies\"]\n",
    "    return {\n",
    "        \"total_requests\":  metrics[\"requests\"],\n",
    "        \"cache_hit_rate\":  round(metrics[\"cache_hits\"] / max(1, metrics[\"requests\"]), 3),\n",
    "        \"rate_limited\":    metrics[\"rate_limited\"],\n",
    "        \"avg_latency_ms\":  round(sum(lats) / max(1, len(lats)) * 1000, 1),\n",
    "        \"cache_size\":      len(cache_queries)\n",
    "    }\n",
    "\n",
    "@app.get(\"/health\")\n",
    "def health():\n",
    "    return {\"status\": \"ok\", \"services\": [\"rag\", \"llm\", \"eval\"]}\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    uvicorn.run(app, host=\"0.0.0.0\", port=8080, log_level=\"warning\")\n",
    "'''\n",
    "\n",
    "with open('gateway.py', 'w') as f:\n",
    "    f.write(gateway_code)\n",
    "print('gateway.py written.')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "l1000012",
   "metadata": {},
   "source": [
    "## 6. Start All Services"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "l1000013",
   "metadata": {},
   "outputs": [],
   "source": [
    "import subprocess, sys, time\n",
    "\n",
    "services = [\n",
    "    ('RAG Service',  'rag_service.py',  8081),\n",
    "    ('LLM Service',  'llm_service.py',  8082),\n",
    "    ('Eval Service', 'eval_service.py', 8083),\n",
    "    ('API Gateway',  'gateway.py',      8080),\n",
    "]\n",
    "\n",
    "procs = []\n",
    "for name, script, port in services:\n",
    "    proc = subprocess.Popen(\n",
    "        [sys.executable, script],\n",
    "        stdout=subprocess.DEVNULL,\n",
    "        stderr=subprocess.DEVNULL\n",
    "    )\n",
    "    procs.append((name, proc, port))\n",
    "    print(f'Starting {name} on port {port} (PID {proc.pid})...')\n",
    "\n",
    "# Wait for all services to be ready\n",
    "time.sleep(6)\n",
    "\n",
    "# Health check all services\n",
    "print('\\nHealth checks:')\n",
    "for name, _, port in services:\n",
    "    try:\n",
    "        r = httpx.get(f'http://localhost:{port}/health', timeout=5)\n",
    "        print(f'  {name}: {r.json()}')\n",
    "    except Exception as e:\n",
    "        print(f'  {name}: NOT READY ({e})')"
   ]
  },
